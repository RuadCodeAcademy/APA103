@using _27_FrontToBackSqlConnection.Areas.AdminPanel.ViewModels.Product
@model List<ProductGetVM>

@{
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Category Table</h4>

                <div class="table-responsive">
                    <a asp-action="create" class="btn btn-outline-success btn-fw">
                        Create
                    </a>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>
                                    Count
                                </th>
                                <th>
                                    Image
                                </th>
                                <th>
                                    Name
                                </th>
                                <th>
                                    Price
                                </th>
                                <th>
                                    SKU
                                </th>
                                <th>
                                    Category
                                </th>
                                <th>
                                    Settings
                                </th>

                            </tr>
                        </thead>
                        <tbody>
                            @foreach (ProductGetVM productGetVM in Model)
                            {
                                <tr>
                                    <td class="py-1">
                                        <p>@(++count)</p>
                                    </td>
                                    <td class="py-1">
                                        <img style="width:70px;height:70px" src="~/assets/images/website-images//@productGetVM.Image" />
                                    </td>
                                    <td class="py-1">
                                        <p>@productGetVM.Name</p>
                                    </td>
                                    <td class="py-1">
                                        <p>@productGetVM.Price</p>
                                    </td>
                                    <td class="py-1">
                                        <p>@productGetVM.SKU</p>
                                    </td>
                                    <td class="py-1">
                                        <p>@productGetVM.CategoryName</p>
                                    </td>
                                    <td class="py-1">
                                        <a asp-action="update" asp-route-id="@productGetVM.Id" class="btn btn-outline-warning btn-fw">Edit</a>
                                        <a asp-action="delete" asp-route-id="@productGetVM.Id" class="btn btn-outline-danger btn-fw">Delete</a>
                                        <a asp-action="Detail" asp-route-id="@productGetVM.Id" class="btn btn-outline-info btn-fw">Details</a>

                                    </td>

                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>