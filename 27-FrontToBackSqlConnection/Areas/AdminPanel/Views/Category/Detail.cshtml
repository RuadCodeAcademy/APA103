@model Category

@{
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Detail Table</h4>

                <div class="table-responsive">
                    <a asp-action="create" class="btn btn-outline-success btn-fw">
                        Create
                    </a>
                    <a asp-action="index" class="btn btn-outline-warning btn-fw">Cancel</a>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>
                                    Count
                                </th>
                                <th>
                                    Name
                                </th>
                                <th>
                                    Products
                                </th>

                               
                            </tr>
                        </thead>
                        <tbody>
                            <tr>

                                <td class="py-1">
                                    <p>@(++count)</p>
                                </td>

                                <td class="py-1">
                                    <p>@Model.Name</p>
                                </td>
                                <td class="py-1">
                                    <p>@(Model.Products?.Count ?? 0)</p>
                                </td>

                            </tr>

                            
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>