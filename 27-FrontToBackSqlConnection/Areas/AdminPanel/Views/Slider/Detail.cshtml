@model Slider



<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Slider Table</h4>

                <div class="table-responsive">
                    <a asp-action="create" class="btn btn-outline-success btn-fw">
                        Create
                    </a>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>
                                    Id
                                </th>
                               
                                <th>
                                    Image
                                </th>
                                <th>
                                    Title
                                </th>
                                <th>
                                    Subtitle
                                </th>
                                <th>
                                    Order
                                </th>
                               

                            </tr>
                        </thead>
                        <tbody>
                           
                                <tr>
                                <td class="py-1">
                                    <p>@Model.Id</p>
                                </td>
                                   
                                    <td class="py-1">
                                        <img style="width:70px;height:70px" src="~/assets/images/website-images//@Model.Image" />
                                    </td>
                                    <td class="py-1">
                                        <p>@Model.Title</p>
                                    </td>
                                    <td class="py-1">
                                        <p>@Model.Subtitle</p>
                                    </td>
                                    <td class="py-1">
                                        <p>@Model.Order</p>
                                    </td>
                                   
                                </tr>

                            <a asp-action="index" class="btn btn-outline-warning btn-fw">Cancel</a>
                            

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>